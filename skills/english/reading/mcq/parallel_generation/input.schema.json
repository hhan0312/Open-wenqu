{
  "type": "object",
  "additionalProperties": false,
  "required": ["skill_id", "passage", "source_question", "generation", "curriculum_text"],
  "properties": {
    "skill_id": { "type": "string" },
    "passage": { "type": "string", "minLength": 1 },
    "curriculum_text": { "type": "string" },
    "source_question": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stem", "options", "correct_answer"],
      "properties": {
        "stem": { "type": "string" },
        "correct_answer": { "type": "string", "enum": ["A", "B", "C", "D"] },
        "options": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "required": ["key", "text"],
            "properties": {
              "key": { "type": "string", "enum": ["A", "B", "C", "D"] },
              "text": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "notes": { "type": ["string", "null"] }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_questions", "detail_questions", "inference_questions"],
      "properties": {
        "total_questions": { "type": "integer", "minimum": 1, "maximum": 10 },
        "detail_questions": { "type": "integer", "minimum": 0, "maximum": 10 },
        "inference_questions": { "type": "integer", "minimum": 0, "maximum": 10 }
      }
    }
  }
}
